{
  "name": "angular-ecmascript-intl-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build-libs": "pnpm --filter ./libs/* build",
    "build": "pnpm build-libs && pnpm --filter demo build",
    "start": "pnpm build-libs && pnpm --filter demo start",
    "test": "pnpm -r test",
    "prelint": "pnpm build-libs",
    "lint": "oxlint . && eslint . --ext .html",
    "release": "release-it",
    "format": "oxfmt",
    "format-check": "oxfmt --check"
  },
  "devDependencies": {
    "@angular/core": "21.2.4",
    "@types/node": "24.12.0",
    "angular-eslint": "21.3.0",
    "eslint": "10.0.3",
    "oxfmt": "0.38.0",
    "oxlint": "1.53.0",
    "rxjs": "7.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "packageManager": "pnpm@10.32.1"
}
